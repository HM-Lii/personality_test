{
  "name": "figure-atlas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node scripts/serve.mjs",
    "test": "node --test test/scoring.test.mjs test/session.test.mjs test/data-contract.test.mjs test/flow.test.mjs",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include=\"src/core/*.mjs\" --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-branches=98 test/scoring.test.mjs test/session.test.mjs test/data-contract.test.mjs test/flow.test.mjs",
    "validate": "node scripts/validate-questions.mjs && node scripts/validate-figures.mjs"
  }
}
